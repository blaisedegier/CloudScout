#!/usr/bin/env bash
# Thin wrapper around 'dotnet run' so you can type 'cloudscout <command>' instead of
# 'dotnet run --project src/CloudScout.Cli -- <command>' every time. Pass-through for all args.
#
# --no-restore skips the NuGet check on every invocation (faster); run 'dotnet restore'
# manually or use 'dotnet build' if you've just changed package references.
# --verbosity quiet suppresses the build summary lines so the CLI's own output comes through cleanly.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
dotnet run --project "$SCRIPT_DIR/src/CloudScout.Cli" --no-restore --verbosity quiet -- "$@"
